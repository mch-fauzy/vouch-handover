# Copy to .env for local dev: cp .env.example .env

# Required for the night-log path. Get it at https://console.anthropic.com - API Keys.
# Without it the service still runs: it returns the structured-events handover and shows a
# notice that the night log was not ingested.
ANTHROPIC_API_KEY=sk-ant-...

# Optional - all have safe defaults (see src/config.ts).
# PORT=3000                       # local server port
# SPEND_CAP_USD=1                 # hard cap on model spend per process
# MODEL_PRICE_IN_PER_MTOK=1       # model input price per million tokens (spend-cap math)
# MODEL_PRICE_OUT_PER_MTOK=5      # model output price per million tokens
# LOW_CONFIDENCE_THRESHOLD=0.7    # below this a model thread key goes to needs-review
# STALE_SHIFTS=2                  # open thread quiet this many shifts is flagged stale
# HOTEL_ID=lumen-sg               # hotel id stamped on the handover
# DATA_DIR=                       # override the data directory if not ./data
